# JWT Configuration
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# PHI Encryption Key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
PHI_ENCRYPTION_KEY=change-me-generate-a-real-fernet-key

# Database
DATABASE_URL=sqlite:///./patient_care.db
